# OWASP ZAP Configuration
# Baseline scan configuration

include:
  # Scan rules
  - 40012  # Cross Site Scripting (Reflected)
  - 40026  # SQL Injection
  - 40027  # Remote File Inclusion
  - 40035  # Command Injection
  - 40038  # Server Side Request Forgery
  
exclude:
  # Exclude specific rules
  - 10054  # Heartbleed OpenSSL Vulnerability (often false positive)

contexts:
  - name: "application-context"
    urls:
      - http://staging-app:8080/.*
    includePaths:
      - .*
    excludePaths: []

report:
  format: html
  theme: corporate
  sections:
    - summary
    - alerts
    - statistics